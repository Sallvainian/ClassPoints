# Configuration for E2E tests running against the local Supabase stack.
# Copy to .env.test (gitignored) and fill in the values from `npx supabase status`.
#
# How to bootstrap:
#   1. Start the local stack:     npx supabase start
#   2. Copy this file:            cp .env.test.example .env.test
#   3. Replace the anon key below with the one from `npx supabase status`
#   4. Seed the test user:        npm run test:seed
#   5. Run tests:                 npm run test:e2e:local

# Local Supabase API — fixed by the CLI, same across machines
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Anon key from `npx supabase status`. Regenerated if you ever run `supabase stop --no-backup`
VITE_SUPABASE_ANON_KEY=REPLACE_WITH_OUTPUT_OF_supabase_status

# Service role key — only used by scripts/seed-test-user.ts to create the auth user
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_OUTPUT_OF_supabase_status

# Test account credentials. Created by scripts/seed-test-user.ts in the LOCAL DB only.
VITE_TEST_EMAIL=test@classpoints.local
VITE_TEST_PASSWORD=test-password-123
