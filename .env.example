# App runtime — read by Vite from `import.meta.env.*`. Only `VITE_*` vars
# reach the browser bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# E2E test user — seeded by `globalSetup` into the local Supabase stack.
VITE_TEST_EMAIL=test@example.local
VITE_TEST_PASSWORD=change-me

# Production secrets are NOT placed here — they live in `fnox.toml`
# (age-encrypted) and are injected by `fnox exec --` for `build`,
# `preview`, `dev:hosted`, and `migrate`. Do NOT add real anon keys
# or service-role keys to this file or to `.env`/`.env.local`.

# Local-only E2E credentials (Supabase service role + local anon) belong
# in `.env.test` — see `.env.test.example` for the template. `.env.test`
# is gitignored and parsed by `playwright.config.ts` to override shell env.
