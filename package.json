{
  "name": "class-points",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:host": "node scripts/dev.mjs --host",
    "dev:hosted": "fnox exec -- vite",
    "build": "tsc -b && fnox exec -- vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "check:bundle": "node scripts/check-bundle.mjs",
    "preview": "fnox exec -- vite preview",
    "supabase:up": "npx supabase start",
    "supabase:down": "npx supabase stop",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:seed": "tsx scripts/seed-test-user.ts",
    "test:e2e:local": "npm run test:seed && playwright test",
    "migrate": "fnox exec -- tsx scripts/migrate-data.ts",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/react-query": "^5.99.2",
    "lucide-react": "^1.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.59.1",
    "@seontechnologies/playwright-utils": "^4.3.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query-devtools": "^5.100.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "supabase": "^2.95.0",
    "tailwindcss": "^4.1.17",
    "tdd-guard-vitest": "^0.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && npm run typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
