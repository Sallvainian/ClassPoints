{
  "name": "class-points",
  "private": true,
  "version": "0.1.0",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:host": "node scripts/dev.mjs --host",
    "dev:hosted": "fnox exec -- vite",
    "build": "tsc -b && fnox exec -- vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit && tsc -p tests/tsconfig.json --noEmit",
    "check:bundle": "node scripts/check-bundle.mjs",
    "cap:build": "tsc -b && fnox exec -- vite build --mode capacitor && node scripts/check-bundle.mjs && npx cap sync",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:run:ios": "npx cap run ios",
    "cap:assets": "npx capacitor-assets generate --ios --android",
    "preview": "fnox exec -- vite preview",
    "supabase:up": "supabase start",
    "supabase:down": "supabase stop",
    "test": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:seed": "tsx scripts/seed-test-user.ts",
    "migrate": "fnox exec -- tsx scripts/migrate-data.ts",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/geist": "^5.2.9",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-query": "^5.101.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@seontechnologies/playwright-utils": "^4.4.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "dotenv": "^17.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.15",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "tar": "^7.5.20",
    "replace": {
      "minimatch": "^3.1.3"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && npm run typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
